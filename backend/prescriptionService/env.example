# ============================================
# PRESCRIPTION SERVICE - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# Server Configuration
SERVER_PORT=8084

# Application Name
APP_NAME=PRESCRIPTION-SERVICE

# ============================================
# DATABASE CONFIGURATION
# ============================================
PRESCRIPTION_DB_URL=jdbc:mysql://localhost:3306/prescriptionService
PRESCRIPTION_DB_USERNAME=your_database_username
PRESCRIPTION_DB_PASSWORD=your_database_password
PRESCRIPTION_DB_DRIVER=com.mysql.cj.jdbc.Driver

# ============================================
# EUREKA CONFIGURATION (Service Discovery)
# ============================================
EUREKA_ENABLED=true
EUREKA_REGISTER_WITH_EUREKA=true
EUREKA_FETCH_REGISTRY=true
EUREKA_SERVER_URL=http://localhost:8761/eureka/
EUREKA_HOSTNAME=localhost

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400000

# ============================================
# JPA/HIBERNATE CONFIGURATION
# ============================================
JPA_HIBERNATE_DDL_AUTO=validate
JPA_SHOW_SQL=false

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_PRESCRIPTION_SERVICE=INFO
LOGGING_LEVEL_HIBERNATE_SQL=WARN
LOGGING_LEVEL_HIBERNATE_TYPE=WARN

# ============================================
# ACTIVE PROFILES (dev, prod, test)
# ============================================
SPRING_PROFILES_ACTIVE=dev
