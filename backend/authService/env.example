# ============================================
# AUTH SERVICE - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# Server Configuration
SERVER_PORT=8081

# Application Name
APP_NAME=AUTH-SERVICE

# ============================================
# EUREKA CONFIGURATION (Service Discovery)
# ============================================
EUREKA_ENABLED=true
EUREKA_REGISTER_WITH_EUREKA=true
EUREKA_FETCH_REGISTRY=true
EUREKA_SERVER_URL=http://localhost:8761/eureka/
EUREKA_HOSTNAME=localhost

# ============================================
# JWT CONFIGURATION
# ============================================
# IMPORTANT: Use the SAME secret across all services
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400000

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_AUTH_SERVICE=INFO

# ============================================
# ACTIVE PROFILES (dev, prod, test)
# ============================================
SPRING_PROFILES_ACTIVE=dev
